{
  "category": "📧 SMTP 邮件服务配置",
  "description": "用于发送验证邮件的 SMTP 服务器设置",
  "fields": {
    "smtp_host": {
      "type": "string",
      "default": "smtp.qq.com",
      "description": "SMTP服务器地址"
    },
    "smtp_port": {
      "type": "int",
      "default": 465,
      "description": "SMTP端口"
    },
    "smtp_user": {
      "type": "string",
      "default": "your_email@qq.com",
      "description": "发信邮箱账号"
    },
    "smtp_password": {
      "type": "string",
      "default": "",
      "description": "邮箱授权码（不是QQ密码！）"
    },
    "smtp_encryption": {
      "type": "string",
      "default": "ssl",
      "description": "加密方式：ssl, tls, none"
    },
    "from_name": {
      "type": "string",
      "default": "Q群验证助手",
      "description": "发件人显示名称"
    },
    "email_domain": {
      "type": "string",
      "default": "@qq.com",
      "description": "用户邮箱后缀（自动用QQ号拼接）"
    }
  }
}
